# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=PME Assistant

# Backend
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/saas_pme
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d

# OpenAI (optional in demo mode)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo

# AWS S3 (optional in demo mode)
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=saas-pme-files

# Stripe (optional in demo mode)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret

# Email (optional in demo mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@saas-pme.com

# Redis (optional, for caching/sessions)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info
